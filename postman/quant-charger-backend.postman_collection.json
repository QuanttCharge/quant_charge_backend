{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Quant Charger Backend",
    "description": "EV Charging Management System — Backend API\n\n## Setup\n1. Run `npm run seed` to create the super admin.\n2. Set `superAdminPassword` collection variable to match `SUPER_ADMIN_PASSWORD` in your `.env`.\n3. Run `npm run dev` and start from **Super Admin Login**.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",                "value": "http://localhost:5000" },
    { "key": "superAdminEmail",        "value": "admin@quantcharge.com" },
    { "key": "superAdminPassword",     "value": "" },
    { "key": "accessToken",            "value": "" },
    { "key": "tenantAdminAccessToken", "value": "" },
    { "key": "tenantAdminEmail",       "value": "" },
    { "key": "setupPasswordToken",     "value": "" },
    { "key": "tenantId",               "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Super Admin — Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.tokens?.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.data.tokens.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{superAdminEmail}}\",\n  \"password\": \"{{superAdminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Super Admin — Create Tenant Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.email) {",
                  "    pm.collectionVariables.set('tenantAdminEmail', json.data.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tenant Admin\",\n  \"email\": \"tenantadmin@example.com\",\n  \"role\": \"tenant_admin\",\n  \"tenantId\": \"{{tenantId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "users"]
            },
            "description": "Set `tenantId` collection variable to an existing tenant's UUID before running."
          },
          "response": []
        },
        {
          "name": "Setup Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{setupPasswordToken}}\",\n  \"password\": \"newpassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/setup-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "setup-password"]
            },
            "description": "Paste the token from the setup email link into the `setupPasswordToken` collection variable."
          },
          "response": []
        },
        {
          "name": "Tenant Admin — Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.tokens?.accessToken) {",
                  "    pm.collectionVariables.set('tenantAdminAccessToken', json.data.tokens.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{tenantAdminEmail}}\",\n  \"password\": \"newpassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Tenant Admin — Create Operator",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantAdminAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Site Operator\",\n  \"email\": \"operator@example.com\",\n  \"role\": \"operator\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "users"]
            },
            "description": "tenantId is auto-assigned from the tenant admin's JWT — no need to pass it."
          },
          "response": []
        },
        {
          "name": "Tenant Admin — Create Driver",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantAdminAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Driver One\",\n  \"email\": \"driver@example.com\",\n  \"role\": \"driver\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "users"]
            }
          },
          "response": []
        },
        {
          "name": "Tenant Admin — Create Support",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantAdminAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Support Agent\",\n  \"email\": \"support@example.com\",\n  \"role\": \"support\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "users"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
